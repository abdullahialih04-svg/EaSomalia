{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/career-guide",  "destination": "/pages/career.html" },
    { "source": "/giving",        "destination": "/pages/giving.html" },
    { "source": "/community",     "destination": "/pages/community.html" },
    { "source": "/projects",      "destination": "/pages/community.html" },
    { "source": "/jobs",          "destination": "/pages/jobs.html" },
    { "source": "/about",         "destination": "/pages/about.html" },
    { "source": "/register",      "destination": "/coming-soon.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
